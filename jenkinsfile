pipeline {
    agent any
    
    environment {
        SCANNER_HOME = tool 'sonar'
        DOCKERHUB_CREDS = 'docker-creds'
        FRONTEND_IMAGE = 'nakshatragowda/frontend'
        BACKEND_IMAGE = 'nakshatragowda/backend'
    }

    stages {
        stage('git checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/NakshatraGowda/note-making-app.git'
            }
        }
     stage('Build and Test'){
         steps{
             dir('backend'){
                 sh 'npm install'
             }
             dir('frontend'){
                 sh 'npm install && npm run build'
             }
         }
     }
        stage('sonarqube scanner'){
            steps{
                sh '''
                $SCANNER_HOME/bin/sonar-scanner \
                -Dsonar.projectKey=notes-app \
                -Dsonar.host.url=http://localhost:9000 \
                -Dsonar.login=<ENTER_YOUR_SONARQUBE_TOKEN> \
                -Dsonar.sources=.
                '''
            }
        }
        stage('build docker image'){
            steps{
                sh 'docker build -t $BACKEND_IMAGE ./backend'
                sh 'docker build -t $FRONTEND_IMAGE ./frontend'
            }
        }
        stage('push docker image to dockerhub'){
            steps{
                withDockerRegistry(credentialsId: DOCKERHUB_CREDS, url: 'https://index.docker.io/v1/'){
                    sh 'docker push $BACKEND_IMAGE'
                    sh 'docker push $FRONTEND_IMAGE'
                }
            }
        }
        stage('git checkout'){
            steps{
            git branch: 'main', url: 'https://github.com/NakshatraGowda/note-making-app.git'
            }
        }
        stage('pull frontend & backend images') {
            steps {
                sh 'docker pull nakshatragowda/backend:latest && docker pull nakshatragowda/frontend:latest'
            }
        }
        stage('stop old containers & start new ones'){
            steps{
              dir('note-making-app'){
                  sh '''
                  docker-compose down || true
                  docker-compose up -d --build
                  '''
                }
            }
        }
       
    }
}
